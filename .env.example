# Server port (default: 3001)
PORT=3001

# CORS - set to the URL where Vite runs in dev (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Optional server-side rationale enrichment.
# When this is empty, decisions still use deterministic KPI overlap scoring.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
